{
  "data": {
    "name": "split_cifar10",
    "task_il": true,
    "n_classes": 10,
    "classes_per_task": 2,
    "normalize": true,
    "val_fraction": 0.05,
    "max_train_per_task": 2500,
    "max_test_per_task": 1000,
    "allow_download": true,
    "seed": 4,
    "label_noise": {
      "rate": 0.2,
      "schedule": "all",
      "noise_type": "symmetric"
    }
  },
  "method": {
    "name": "gated_replay",
    "buffer_size": 500,
    "batch_size": 32,
    "error_gated": true,
    "gate_level": "sample",
    "gate": {
      "signal": "error",
      "error_threshold": 1.0,
      "gamma": 3.0
    },
    "seed": 4
  },
  "train": {
    "epochs": 8,
    "batch_size": 128
  }
}