{
  "data": {
    "name": "permuted_mnist",
    "source": "mnist",
    "multihead": false,
    "n_tasks": 5,
    "max_train_per_task": 3000,
    "val_fraction": 0.1,
    "allow_download": true,
    "fallback_synthetic": true,
    "seed": 1,
    "label_noise": {
      "rate": 0.0,
      "schedule": "clean",
      "noise_type": "symmetric"
    }
  },
  "method": {
    "name": "si",
    "lambda": 1.0,
    "xi": 0.1,
    "seed": 1
  },
  "train": {
    "epochs": 8,
    "batch_size": 128
  }
}